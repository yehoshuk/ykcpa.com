---
import Layout from '@layouts/Default.astro';
import RecentBlogPosts from '@components/generic/RecentBlogPosts.astro';
import MobileSocials from '@components/home/MobileSocials.astro';
import { Button } from '@eliancodes/brutal-ui';
import { Card } from '@eliancodes/brutal-ui';
---

<Layout
  title='Home'
  pageTitle='ykcpa.com | Home'
  description='A scratchpad for Excel, accounting, AI/LLM topics, and other technical notes by Josh Krupnick.'
>
  <main class='bg-pink p-6'>
    <MobileSocials />
    <section id='about' class='grid md:grid-cols-8 gap-8 mt-4'>
      <h2 class='hidden'>About ykcpa.com</h2>
      <div class='col-span-4'>
        <Card>
          <div class='flex flex-col justify-between items-start gap-4'>
            <p class='mt-4 outfit text-2xl md:text-5xl lg:text-7xl'>
              Welcome to <span class='text-white'>ykcpa.com</span>
            </p>
            <p class='mt-2 outfit text-xl md:text-3xl lg:text-5xl'>
              Notes on Excel, accounting, AI, and other topics of interest.
            </p>
            <Button target={'_self'} href='/blog/'>
              Browse my notes &rarr;
            </Button>
          </div>
        </Card>
      </div>
      <div class='col-span-2'>
        <Card>
          <h2 class='text-2xl md:text-4xl lg:text-6xl mb-8 dm-serif'>
            Topics
          </h2>
          <ul class='flex gap-4 flex-wrap poppins text-lg'>
            <li>Excel & VBA</li>
            <li>Accounting</li>
            <li>AI & LLMs</li>
            <li>Prompting</li>
            <li>Software</li>
          </ul>
        </Card>
      </div>
      <div class='col-span-2'>
        <Card>
          <h2 class='text-2xl md:text-4xl lg:text-6xl mb-4 dm-serif'>
            About
          </h2>
          <p class='poppins'>
            This site is where I stash notes on Excel, accounting, software and
            other topics of personal interest. Feel free to browse around... enjoy!
          </p>
        </Card>
      </div>
    </section>
    <RecentBlogPosts />
  </main>
</Layout>
